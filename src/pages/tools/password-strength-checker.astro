---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Password strength checker — how strong is your password?';
const description =
  'Free password strength checker that models how real attackers crack passwords. See how long yours would survive — it runs entirely in your browser, nothing is sent or stored.';

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is it safe to type my password into this checker?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The check runs entirely in your browser using JavaScript. Your password is never sent over the internet, saved, or logged — you could disconnect from wifi and it would still work.',
      },
    },
    {
      '@type': 'Question',
      name: 'What makes a password strong?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Length matters most — aim for at least 12 to 16 characters. A handful of unrelated words is both strong and memorable. Avoid dictionary words with predictable swaps like P@ssw0rd, because crackers try those first. Every account needs its own unique password, which is why a password manager is the easiest way to stay safe.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is the time-to-crack calculated?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The tool uses zxcvbn, an open-source estimator built by Dropbox, to model how real password crackers work — recognising dictionary words, names, dates, keyboard patterns and leet substitutions like P@ssw0rd — then shows the time to crack in a fast offline attack of about 10 billion guesses per second against a stolen password database.',
      },
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faq)} />

  <div class="pwtool" style="--c:#7c3aed">
    <p class="breadcrumb"><a href="/">Home</a> › <a href="/tools/">Tools</a> › Password strength checker</p>

    <h1>How strong is your password?</h1>
    <p class="lead">Type a password and see how long it would survive a real attack — and exactly what's making it weak.</p>

    <div class="privacy">
      <span aria-hidden="true">🔒</span>
      <span><strong>Nothing leaves your device.</strong> This check runs entirely in your browser. Your password is never sent over the internet, saved, or logged. You can even turn off wifi and it still works.</span>
    </div>

    <div class="tool">
      <label class="fld" for="pw">Enter a password to test</label>
      <div class="inrow">
        <input id="pw" type="password" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="Type or paste a password…" />
        <button class="ghost" id="toggle" type="button" aria-label="Show or hide password">Show</button>
        <button class="ghost" id="gen" type="button">Generate</button>
      </div>

      <div class="meter" id="meter" aria-hidden="true">
        <span class="seg"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span>
      </div>
      <div class="resrow" aria-live="polite">
        <span class="verdict" id="verdict">Waiting…</span>
        <span class="crack">Time to crack: <b id="crack">—</b></span>
      </div>

      <ul class="fb" id="fb"></ul>

      <div class="chips">
        Don't want to type yours? Try one:
        <span class="chip" data-pw="password1">password1</span>
        <span class="chip" data-pw="P@ssw0rd!">P@ssw0rd!</span>
        <span class="chip" data-pw="Liverpool2024">Liverpool2024</span>
        <span class="chip" data-pw="correct-horse-battery-staple">correct-horse-battery-staple</span>
      </div>
    </div>

    <div class="cta">
      <h2>Here's the catch</h2>
      <p>A password strong enough to be safe is too long to remember — and you need a <em>different</em> one for every account. That isn't laziness, it's impossible by hand. A password manager creates and remembers them for you, so you only ever remember one. It's the single biggest upgrade you can make to your online safety.</p>
      <a class="btn" href="/articles/best-free-password-managers/">See the best free password managers →</a>
      <a class="btn2" href="/articles/1password-vs-bitwarden/">1Password vs Bitwarden</a>
    </div>

    <details>
      <summary>How this estimate works (and what to trust)</summary>
      <p>This checker uses <strong>zxcvbn</strong>, the open-source strength estimator built by Dropbox. Instead of naively counting character types, it models how real attackers work: it looks for dictionary words, names, dates, keyboard runs like <em>qwerty</em>, repeats, and predictable substitutions such as <em>P@ssw0rd</em>. It then estimates how many guesses your password needs and shows the time to crack it in a <strong>fast offline attack</strong> — about 10 billion guesses a second, a realistic rate against a stolen password database.</p>
      <p>It's a guide, not a guarantee. The real lessons are simple: <strong>length beats complexity</strong>, every account needs its <strong>own</strong> password, and a long string of unrelated words beats a short "complicated" one like <em>P@ssw0rd!</em>.</p>
    </details>

    <h2>Common questions</h2>
    <h3>Is it safe to type my password here?</h3>
    <p>Yes — the check happens inside your browser and your password never leaves your device. If you're still uneasy, hit <strong>Generate</strong> and test one of those instead.</p>
    <h3>What actually makes a password strong?</h3>
    <p><strong>Length first.</strong> A passphrase of four or five unrelated words is both very strong and easy to remember. Avoid names, dates and single dictionary words — and don't rely on swaps like <em>P@ssw0rd</em>, which crackers try first. Never reuse the same password across sites — see <a href="/articles/how-to-create-a-strong-password/">how to create strong passwords you'll actually remember</a>.</p>
    <h3>How do I keep track of dozens of strong passwords?</h3>
    <p>You don't — a password manager does it for you. Start with <a href="/articles/how-to-set-up-a-password-manager/">our simple setup walkthrough</a>, or see <a href="/articles/are-password-managers-safe/">why password managers are safe</a>. You can also <a href="/tools/has-my-password-been-breached/">check whether a password has leaked</a> in a breach.</p>
  </div>
</BaseLayout>

<style is:global>
  .pwtool { --c: #7c3aed; max-width: 760px; }
  .pwtool .privacy { display:flex; gap:10px; align-items:flex-start; background:#ecfdf5; border:1px solid #a7f3d0; border-left:4px solid var(--ok); border-radius:12px; padding:12px 14px; font-size:.95rem; margin:0 0 22px; }
  .pwtool .privacy strong { color:#065f46; }
  .pwtool .tool { background:var(--bg-soft); border:1px solid var(--border); border-radius:var(--radius); padding:22px; }
  .pwtool label.fld { display:block; font-weight:700; color:var(--brand); margin:0 0 8px; }
  .pwtool .inrow { display:flex; gap:8px; flex-wrap:wrap; }
  .pwtool #pw { flex:1; font-size:1.15rem; padding:13px 14px; border:1.5px solid var(--border-strong); border-radius:10px; font-family:var(--font); min-width:160px; }
  .pwtool #pw:focus { outline:none; border-color:var(--accent-dark); }
  .pwtool .ghost { border:1.5px solid var(--border-strong); background:#fff; border-radius:10px; padding:0 14px; font-weight:700; color:var(--accent-dark); cursor:pointer; font-size:.92rem; white-space:nowrap; }
  .pwtool .ghost:hover { border-color:var(--accent-dark); }
  .pwtool .meter { display:flex; gap:6px; margin:18px 0 10px; }
  .pwtool .seg { height:10px; flex:1; border-radius:999px; background:#e2e8f0; transition:background .2s; }
  .pwtool .resrow { display:flex; justify-content:space-between; align-items:baseline; gap:12px; flex-wrap:wrap; }
  .pwtool .verdict { font-weight:800; font-size:1.15rem; color:var(--muted); }
  .pwtool .crack { font-size:.95rem; color:var(--muted); }
  .pwtool .crack b { color:var(--fg); font-size:1.05rem; }
  .pwtool ul.fb { list-style:none; padding:0; margin:14px 0 0; }
  .pwtool ul.fb li { padding:7px 0 7px 26px; position:relative; font-size:.96rem; color:var(--fg); border-top:1px solid var(--border); }
  .pwtool ul.fb li::before { content:"!"; position:absolute; left:0; top:7px; width:18px; height:18px; background:var(--cta); color:#fff; border-radius:50%; font-size:.72rem; font-weight:800; display:flex; align-items:center; justify-content:center; }
  .pwtool ul.fb li.good::before { content:"\2713"; background:var(--ok); }
  .pwtool .chips { margin:18px 0 0; font-size:.9rem; color:var(--muted); }
  .pwtool .chip { display:inline-block; margin:5px 6px 0 0; padding:5px 11px; border:1px solid var(--border-strong); border-radius:999px; background:#fff; cursor:pointer; font-size:.85rem; color:var(--accent-dark); font-weight:600; }
  .pwtool .chip:hover { background:var(--bg-soft); }
  .pwtool .cta { margin:26px 0 0; background:linear-gradient(180deg,#fff7ed,#fffdf9); border:1px solid #fed7aa; border-radius:var(--radius); padding:20px 22px; }
  .pwtool .cta h2 { margin:0 0 6px; font-size:1.2rem; color:var(--brand); }
  .pwtool .cta p { margin:0 0 14px; color:#3f4756; font-size:1rem; }
  .pwtool .btn2 { display:inline-block; border:1.5px solid var(--brand); color:var(--brand); background:#fff; text-decoration:none; font-weight:700; padding:9px 16px; border-radius:10px; }
  .pwtool .btn2:hover { background:var(--brand); color:#fff; }
  .pwtool details { margin:24px 0 0; font-size:.95rem; color:var(--muted); }
  .pwtool details summary { cursor:pointer; font-weight:700; color:var(--brand); }
</style>

<script>
  import zxcvbn from 'zxcvbn';

  const WORDS = "river,amber,tiger,maple,cloud,stone,ember,otter,plum,frost,raven,cedar,vivid,quill,brook,flint,marsh,thorn,glade,heron,lunar,onyx,pearl,quartz,ridge,sage,topaz,umber,violet,willow,zephyr,anchor,bramble,copper,dapple,fennel,gable,harbor,indigo,jasper,kelp,lichen,meadow,nectar,opal,pebble,reed,saffron,tundra,velvet,walnut,yarrow,almond,beacon,cobalt,driftwood,echo,falcon,grove,hazel,iris,juniper,kestrel".split(",");
  const COLORS = ["#dc2626", "#f97316", "#eab308", "#16a34a", "#15803d"];
  const LABELS = ["Very weak", "Weak", "Fair", "Strong", "Very strong"];

  const pwEl = document.getElementById("pw");
  const segs = document.querySelectorAll("#meter .seg");
  const verdict = document.getElementById("verdict");
  const crack = document.getElementById("crack");
  const fbEl = document.getElementById("fb");
  const toggle = document.getElementById("toggle");

  function render() {
    const pw = pwEl.value;
    if (!pw) {
      verdict.textContent = "Waiting…"; verdict.style.color = "var(--muted)";
      crack.textContent = "—"; fbEl.innerHTML = "";
      segs.forEach((s) => { s.style.background = "#e2e8f0"; });
      return;
    }
    const r = zxcvbn(pw.slice(0, 128));
    const score = r.score;
    const col = COLORS[score];
    segs.forEach((s, i) => { s.style.background = i <= score ? col : "#e2e8f0"; });
    verdict.textContent = LABELS[score]; verdict.style.color = col;
    crack.textContent = r.crack_times_display.offline_fast_hashing_1e10_per_second;

    const items = [];
    if (r.feedback && r.feedback.warning) items.push({ t: r.feedback.warning });
    if (r.feedback && r.feedback.suggestions) r.feedback.suggestions.forEach((s) => items.push({ t: s }));
    if (score >= 3 && items.length === 0) items.push({ good: true, t: "Long and unpredictable — this would take an attacker lifetimes. Now you just need a way to remember it." });
    fbEl.innerHTML = "";
    items.forEach((it) => { const li = document.createElement("li"); if (it.good) li.className = "good"; li.textContent = it.t; fbEl.appendChild(li); });
  }

  function genPass() {
    const arr = new Uint32Array(5); crypto.getRandomValues(arr);
    const w = [];
    for (let i = 0; i < 4; i++) {
      let word = WORDS[arr[i] % WORDS.length];
      if (arr[i] % 2 === 0) word = word.charAt(0).toUpperCase() + word.slice(1);
      w.push(word);
    }
    const sym = "!@#$%?*".charAt(arr[4] % 7);
    const num = (arr[4] % 90) + 10;
    return w.join("-") + sym + num;
  }

  pwEl.addEventListener("input", render);
  toggle.addEventListener("click", function () { const t = pwEl.type === "password"; pwEl.type = t ? "text" : "password"; this.textContent = t ? "Hide" : "Show"; });
  document.getElementById("gen").addEventListener("click", function () { pwEl.type = "text"; toggle.textContent = "Hide"; pwEl.value = genPass(); render(); });
  document.querySelectorAll(".chip").forEach(function (c) { c.addEventListener("click", function () { pwEl.type = "text"; toggle.textContent = "Hide"; pwEl.value = c.getAttribute("data-pw"); render(); }); });
</script>
