---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Password strength checker — how strong is your password?';
const description =
  'Free password strength checker: see how long your password would take to crack and what makes it weak. Runs entirely in your browser — nothing is sent or stored.';

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is it safe to type my password into this checker?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. The check runs entirely in your browser using JavaScript. Your password is never sent over the internet, saved, or logged — you could disconnect from wifi and it would still work.',
      },
    },
    {
      '@type': 'Question',
      name: 'What makes a password strong?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Length matters most — aim for at least 12 to 16 characters. A handful of unrelated words is both strong and memorable. Every account needs its own unique password, which is why a password manager is the easiest way to stay safe.',
      },
    },
    {
      '@type': 'Question',
      name: 'How is the time-to-crack calculated?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The tool estimates how many guesses your password needs and divides by about 10 billion guesses per second — a realistic rate for an attacker working offline on a stolen password database. It also penalises common passwords, dictionary words, keyboard runs, repeats, dates and look-alike swaps like P@ssw0rd.',
      },
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faq)} />

  <div class="pwtool">
    <p class="breadcrumb"><a href="/">Home</a> › <a href="/tools/">Tools</a> › Password strength checker</p>

    <h1>How strong is your password?</h1>
    <p class="lead">Type a password and see how long it would take a modern attacker to crack it — and exactly what's making it weak.</p>

    <div class="privacy">
      <span aria-hidden="true">🔒</span>
      <span><strong>Nothing leaves your device.</strong> This check runs entirely in your browser. Your password is never sent over the internet, saved, or logged. You can even turn off wifi and it still works.</span>
    </div>

    <div class="tool">
      <label class="fld" for="pw">Enter a password to test</label>
      <div class="inrow">
        <input id="pw" type="password" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="Type or paste a password…" />
        <button class="ghost" id="toggle" type="button" aria-label="Show or hide password">Show</button>
        <button class="ghost" id="gen" type="button">Generate</button>
      </div>

      <div class="meter" id="meter" aria-hidden="true">
        <span class="seg"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span><span class="seg"></span>
      </div>
      <div class="resrow" aria-live="polite">
        <span class="verdict" id="verdict">Waiting…</span>
        <span class="crack">Time to crack: <b id="crack">—</b></span>
      </div>

      <ul class="fb" id="fb"></ul>

      <div class="chips">
        Don't want to type yours? Try one:
        <span class="chip" data-pw="password1">password1</span>
        <span class="chip" data-pw="P@ssw0rd!">P@ssw0rd!</span>
        <span class="chip" data-pw="Liverpool2024">Liverpool2024</span>
        <span class="chip" data-pw="correct-horse-battery-staple">correct-horse-battery-staple</span>
      </div>
    </div>

    <div class="cta">
      <h2>Here's the catch</h2>
      <p>A password strong enough to be safe is too long to remember — and you need a <em>different</em> one for every account. That isn't laziness, it's impossible by hand. A password manager creates and remembers them for you, so you only ever remember one. It's the single biggest upgrade you can make to your online safety.</p>
      <a class="btn" href="/articles/best-free-password-managers/">See the best free password managers →</a>
      <a class="btn2" href="/articles/1password-vs-bitwarden/">1Password vs Bitwarden</a>
    </div>

    <details>
      <summary>How this estimate works (and what to trust)</summary>
      <p>This tool estimates the number of guesses needed to crack your password and divides by <strong>10 billion guesses per second</strong> — a realistic rate for an attacker with a good graphics card working on a stolen, poorly-protected password database (an "offline" attack). It also penalises common passwords, dictionary words, keyboard runs like <em>qwerty</em>, repeated characters, dates, and look-alike swaps like <em>P@ssw0rd</em>.</p>
      <p>It's a guide, not a guarantee. The real lessons are simple: <strong>length beats complexity</strong>, every account needs its <strong>own</strong> password, and a password manager is the easy way to do both. It's also why a long string of random words beats a short "complicated" one.</p>
    </details>

    <h2>Common questions</h2>
    <h3>Is it safe to type my password here?</h3>
    <p>Yes — the check happens inside your browser and your password never leaves your device. If you're still uneasy, hit <strong>Generate</strong> and test one of those instead.</p>
    <h3>What actually makes a password strong?</h3>
    <p><strong>Length first.</strong> A passphrase of four or five unrelated words is both very strong and easy to remember. Avoid names, dates and single dictionary words. And never reuse the same password across sites — see <a href="/articles/how-to-create-a-strong-password/">how to create strong passwords you'll actually remember</a>.</p>
    <h3>How do I keep track of dozens of strong passwords?</h3>
    <p>You don't — a password manager does it for you. Start with <a href="/articles/how-to-set-up-a-password-manager/">our simple setup walkthrough</a>, or see <a href="/articles/are-password-managers-safe/">why password managers are safe</a>.</p>
  </div>
</BaseLayout>

<style is:global>
  .pwtool { --c: #7c3aed; max-width: 760px; }
  .pwtool .privacy { display:flex; gap:10px; align-items:flex-start; background:#ecfdf5; border:1px solid #a7f3d0; border-left:4px solid var(--ok); border-radius:12px; padding:12px 14px; font-size:.95rem; margin:0 0 22px; }
  .pwtool .privacy strong { color:#065f46; }
  .pwtool .tool { background:var(--bg-soft); border:1px solid var(--border); border-radius:var(--radius); padding:22px; }
  .pwtool label.fld { display:block; font-weight:700; color:var(--brand); margin:0 0 8px; }
  .pwtool .inrow { display:flex; gap:8px; }
  .pwtool #pw { flex:1; font-size:1.15rem; padding:13px 14px; border:1.5px solid var(--border-strong); border-radius:10px; font-family:var(--font); min-width:0; }
  .pwtool #pw:focus { outline:none; border-color:var(--accent-dark); }
  .pwtool .ghost { border:1.5px solid var(--border-strong); background:#fff; border-radius:10px; padding:0 14px; font-weight:700; color:var(--accent-dark); cursor:pointer; font-size:.92rem; white-space:nowrap; }
  .pwtool .ghost:hover { border-color:var(--accent-dark); }
  .pwtool .meter { display:flex; gap:6px; margin:18px 0 10px; }
  .pwtool .seg { height:10px; flex:1; border-radius:999px; background:#e2e8f0; transition:background .2s; }
  .pwtool .resrow { display:flex; justify-content:space-between; align-items:baseline; gap:12px; flex-wrap:wrap; }
  .pwtool .verdict { font-weight:800; font-size:1.15rem; color:var(--muted); }
  .pwtool .crack { font-size:.95rem; color:var(--muted); }
  .pwtool .crack b { color:var(--fg); font-size:1.05rem; }
  .pwtool ul.fb { list-style:none; padding:0; margin:14px 0 0; }
  .pwtool ul.fb li { padding:7px 0 7px 26px; position:relative; font-size:.96rem; color:var(--fg); border-top:1px solid var(--border); }
  .pwtool ul.fb li::before { content:"!"; position:absolute; left:0; top:7px; width:18px; height:18px; background:var(--cta); color:#fff; border-radius:50%; font-size:.72rem; font-weight:800; display:flex; align-items:center; justify-content:center; }
  .pwtool ul.fb li.good::before { content:"\2713"; background:var(--ok); }
  .pwtool .chips { margin:18px 0 0; font-size:.9rem; color:var(--muted); }
  .pwtool .chip { display:inline-block; margin:5px 6px 0 0; padding:5px 11px; border:1px solid var(--border-strong); border-radius:999px; background:#fff; cursor:pointer; font-size:.85rem; color:var(--accent-dark); font-weight:600; }
  .pwtool .chip:hover { background:var(--bg-soft); }
  .pwtool .cta { margin:26px 0 0; background:linear-gradient(180deg,#fff7ed,#fffdf9); border:1px solid #fed7aa; border-radius:var(--radius); padding:20px 22px; }
  .pwtool .cta h2 { margin:0 0 6px; font-size:1.2rem; color:var(--brand); }
  .pwtool .cta p { margin:0 0 14px; color:#3f4756; font-size:1rem; }
  .pwtool .btn2 { display:inline-block; border:1.5px solid var(--brand); color:var(--brand); background:#fff; text-decoration:none; font-weight:700; padding:9px 16px; border-radius:10px; }
  .pwtool .btn2:hover { background:var(--brand); color:#fff; }
  .pwtool details { margin:24px 0 0; font-size:.95rem; color:var(--muted); }
  .pwtool details summary { cursor:pointer; font-weight:700; color:var(--brand); }
</style>

<script is:inline>
(function(){
  var COMMON = new Set(("password,password1,password123,123456,12345,1234,12345678,123456789,1234567,1234567890,111111,123123,000000,654321,666666,121212,qwerty,qwerty123,qwertyuiop,qazwsx,1q2w3e4r,1qaz2wsx,asdfgh,asdfghjkl,zxcvbnm,abc123,admin,administrator,letmein,welcome,welcome1,login,passw0rd,p@ssw0rd,iloveyou,monkey,dragon,sunshine,princess,football,baseball,basketball,superman,batman,master,hello,hello123,whatever,trustno1,shadow,freedom,ginger,starwars,computer,michelle,jordan,jordan23,harley,hunter,ranger,buster,soccer,hockey,killer,george,charlie,andrew,thomas,jessica,pepper,daniel,access,samsung,ashley,liverpool,arsenal,chelsea,manutd,london,england,summer,winter,money,secret,please,cookie,chocolate,naruto,pokemon,minecraft,test,test123,changeme,abc,abcd,abcd1234,aaaaaa,asdf,asdf1234,google,facebook,internet,test1234,qwe123,zaq12wsx").split(","));
  var WORDS = "river,amber,tiger,maple,cloud,stone,ember,otter,plum,frost,raven,cedar,vivid,quill,brook,flint,marsh,thorn,glade,heron,lunar,onyx,pearl,quartz,ridge,sage,topaz,umber,violet,willow,zephyr,anchor,bramble,copper,dapple,fennel,gable,harbor,indigo,jasper,kelp,lichen,meadow,nectar,opal,pebble,reed,saffron,tundra,velvet,walnut,yarrow,almond,beacon,cobalt,driftwood,echo,falcon,grove,hazel,iris,juniper,kestrel".split(",");
  var SEQS = ["abcdefghijklmnopqrstuvwxyz","qwertyuiop","asdfghjkl","zxcvbnm","01234567890","0123456789"];
  function pool(pw){var p=0;if(/[a-z]/.test(pw))p+=26;if(/[A-Z]/.test(pw))p+=26;if(/[0-9]/.test(pw))p+=10;if(/[^A-Za-z0-9]/.test(pw))p+=33;return p||1;}
  function hasSeq(s){s=s.toLowerCase();for(var i=0;i<SEQS.length;i++){var seq=SEQS[i];for(var j=0;j+4<=seq.length;j++){var sub=seq.substr(j,4);if(s.indexOf(sub)>=0)return true;var rev=sub.split("").reverse().join("");if(s.indexOf(rev)>=0)return true;}}return false;}
  function maxRun(s){var m=1,c=1;for(var i=1;i<s.length;i++){if(s[i]===s[i-1]){c++;if(c>m)m=c;}else c=1;}return m;}
  function deleet(s){return s.toLowerCase().replace(/@/g,"a").replace(/0/g,"o").replace(/1/g,"i").replace(/3/g,"e").replace(/\$/g,"s").replace(/5/g,"s").replace(/7/g,"t").replace(/4/g,"a").replace(/!/g,"i");}
  function estimate(pw){
    if(!pw) return null;
    var low=pw.toLowerCase(), fb=[], entropy=pw.length*Math.log2(pool(pw));
    if(COMMON.has(low)){entropy=Math.min(entropy,8);fb.push("This is one of the most common passwords in the world — it's tried in the first second.");}
    if(COMMON.has(deleet(low))&&!COMMON.has(low)){entropy=Math.min(entropy,14);fb.push("Swapping letters for look-alikes (like P@ssw0rd) is the very first thing crackers try.");}
    if(/^[a-zA-Z]+$/.test(pw)&&pw.length<=14){entropy=Math.min(entropy,pw.length*2.6);fb.push("A single word is broken fast by dictionary attacks — combine several unrelated words.");}
    if(/^[0-9]+$/.test(pw)){entropy=Math.min(entropy,pw.length*Math.log2(10));fb.push("Digits only (a PIN or date) is very weak — mix in words and symbols.");}
    if(/(19|20)\d{2}/.test(pw)){entropy=Math.min(entropy,entropy-4);fb.push("Contains a year — birthdays and dates are easy to guess.");}
    if(hasSeq(low)){entropy=Math.min(entropy,entropy*0.62);fb.push("Contains a keyboard or counting run (like qwerty or 1234).");}
    if(maxRun(pw)>=3){entropy=Math.min(entropy,entropy*0.7);fb.push("Repeated characters add almost no strength.");}
    if(pw.length<8){fb.push("It's short. Length is the biggest factor — aim for 12+ characters.");}
    entropy=Math.max(entropy,1);
    var seconds=Math.pow(2,entropy)/2/1e10;
    var score,label;
    if(entropy<28){score=0;label="Very weak";}
    else if(entropy<40){score=1;label="Weak";}
    else if(entropy<56){score=2;label="Fair";}
    else if(entropy<72){score=3;label="Strong";}
    else{score=4;label="Very strong";}
    if(score>=3&&fb.length===0){fb.push({good:true,t:"Long and varied — this would take an attacker lifetimes. Now you just need a way to remember it."});}
    return {seconds:seconds,score:score,label:label,fb:fb};
  }
  function human(s){
    if(s<1) return "instantly";
    var u=[["second",1],["minute",60],["hour",3600],["day",86400],["month",2592000],["year",31536000]];
    if(s>=31536000*1e6) return "effectively forever";
    if(s>=31536000*100){var c=Math.round(s/31536000/100);return c.toLocaleString()+" centuries";}
    for(var i=u.length-1;i>=0;i--){if(s>=u[i][1]){var v=Math.round(s/u[i][1]);return v.toLocaleString()+" "+u[i][0]+(v!==1?"s":"");}}
    return "instantly";
  }
  var COLORS=["#dc2626","#f97316","#eab308","#16a34a","#15803d"];
  var pwEl=document.getElementById("pw"),segs=document.querySelectorAll("#meter .seg"),
      verdict=document.getElementById("verdict"),crack=document.getElementById("crack"),fbEl=document.getElementById("fb");
  if(!pwEl) return;
  function render(){
    var r=estimate(pwEl.value);
    if(!r){verdict.textContent="Waiting…";verdict.style.color="var(--muted)";crack.textContent="—";fbEl.innerHTML="";segs.forEach(function(s){s.style.background="#e2e8f0";});return;}
    var col=COLORS[r.score];
    segs.forEach(function(s,i){s.style.background=i<=r.score?col:"#e2e8f0";});
    verdict.textContent=r.label;verdict.style.color=col;
    crack.textContent=human(r.seconds);
    fbEl.innerHTML="";
    r.fb.forEach(function(item){var li=document.createElement("li");if(item.good){li.className="good";li.textContent=item.t;}else{li.textContent=item;}fbEl.appendChild(li);});
  }
  function genPass(){
    var arr=new Uint32Array(5);crypto.getRandomValues(arr);
    var w=[];for(var i=0;i<4;i++){var word=WORDS[arr[i]%WORDS.length];if(arr[i]%2===0)word=word.charAt(0).toUpperCase()+word.slice(1);w.push(word);}
    var sym="!@#$%?*".charAt(arr[4]%7);var num=arr[4]%90+10;
    return w.join("-")+sym+num;
  }
  pwEl.addEventListener("input",render);
  document.getElementById("toggle").addEventListener("click",function(){var t=pwEl.type==="password";pwEl.type=t?"text":"password";this.textContent=t?"Hide":"Show";});
  document.getElementById("gen").addEventListener("click",function(){pwEl.type="text";document.getElementById("toggle").textContent="Hide";pwEl.value=genPass();render();});
  document.querySelectorAll(".chip").forEach(function(c){c.addEventListener("click",function(){pwEl.type="text";document.getElementById("toggle").textContent="Hide";pwEl.value=c.getAttribute("data-pw");render();});});
})();
</script>
