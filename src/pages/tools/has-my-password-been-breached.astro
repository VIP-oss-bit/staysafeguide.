---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Has your password been breached? Free Pwned Password check';
const description =
  'Check instantly and privately whether a password has appeared in a known data breach. Your password never leaves your browser — only a partial fingerprint is sent.';

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is it safe to type my password into this breach checker?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Your password is turned into a fingerprint (a SHA-1 hash) inside your browser, and only the first five characters of that fingerprint are sent to Have I Been Pwned. Your password, and even the full fingerprint, never leave your device. This privacy-safe method is called k-anonymity.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does it mean if my password was found?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'It means that exact password has appeared in a known data breach and is on lists that criminals use to break into accounts. Stop using it everywhere, change it on any account that has it, and switch to a unique password per site.',
      },
    },
    {
      '@type': 'Question',
      name: 'My password was not found — does that mean it is strong?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. "Not found" only means it has not appeared in a known leak yet. A weak password can still be cracked by guessing. Check how strong it is as well, and use a long, unique password for every account.',
      },
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faq)} />

  <div class="pwtool">
    <p class="breadcrumb"><a href="/">Home</a> › <a href="/tools/">Tools</a> › Has your password been breached?</p>

    <h1>Has your password been breached?</h1>
    <p class="lead">Check instantly whether a password has appeared in a known data breach — privately. Your password never leaves your device.</p>

    <div class="privacy">
      <span aria-hidden="true">🔒</span>
      <span><strong>This is genuinely private.</strong> Your password is turned into a fingerprint inside your browser, and only the <strong>first 5 characters</strong> of that fingerprint are ever sent — never your password, and never the full fingerprint. It's a privacy-safe method called <em>k-anonymity</em>.</span>
    </div>

    <div class="tool">
      <label class="fld" for="pw">Enter a password to check</label>
      <div class="inrow">
        <input id="pw" type="password" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" placeholder="Type or paste a password…" />
        <button class="ghost" id="toggle" type="button" aria-label="Show or hide password">Show</button>
        <button class="btn check" id="check" type="button">Check</button>
      </div>

      <div class="result" id="result" aria-live="polite"></div>

      <div class="chips">
        Try one (these are safe examples):
        <span class="chip" data-pw="password">password</span>
        <span class="chip" data-pw="123456">123456</span>
        <span class="chip" data-pw="Liverpool2024">Liverpool2024</span>
        <span class="chip" data-pw="river-amber-tiger-maple-83x">a long random one</span>
      </div>
    </div>

    <div class="cta">
      <h2>If your password turned up in a breach</h2>
      <p>Don't panic, but do act. Change it on every account that uses it, and never use it again. The only realistic way to have a different strong password everywhere is to let a password manager create and remember them for you.</p>
      <a class="btn" href="/articles/best-free-password-managers/">See the best free password managers →</a>
      <a class="btn2" href="/articles/how-to-set-up-a-password-manager/">How to set one up</a>
    </div>

    <details>
      <summary>How this works (and why it's safe)</summary>
      <p>When you press Check, your browser converts your password into a 40-character fingerprint called a SHA-1 hash. It sends only the <strong>first five characters</strong> to the <a href="https://haveibeenpwned.com/Passwords" target="_blank" rel="noopener">Have I Been Pwned</a> Pwned Passwords service, which returns every leaked fingerprint starting with those five characters — often hundreds of them. Your browser then checks the rest of the match locally. So the service never learns your password, or even which one of the hundreds you were asking about.</p>
      <p>The database holds over 14 billion real passwords exposed in data breaches. Powered by Have I Been Pwned, the free service run by security researcher Troy Hunt.</p>
    </details>

    <h2>Common questions</h2>
    <h3>It says my password was found — what now?</h3>
    <p>That password is on lists criminals actively use. Change it anywhere you've used it, and give every account its own unique password. Here's <a href="/articles/how-to-check-if-your-password-has-been-leaked/">the full guide to leaked passwords</a>, including how to check your <em>email</em> too.</p>
    <h3>It says "not found" — am I safe?</h3>
    <p>Safer, but "not found" only means it hasn't leaked <em>yet</em>. A short or obvious password can still be guessed. Test how strong it is with our <a href="/tools/password-strength-checker/">password strength checker</a>.</p>
  </div>
</BaseLayout>

<style is:global>
  .pwtool { --c: #7c3aed; max-width: 760px; }
  .pwtool .privacy { display:flex; gap:10px; align-items:flex-start; background:#ecfdf5; border:1px solid #a7f3d0; border-left:4px solid var(--ok); border-radius:12px; padding:12px 14px; font-size:.95rem; margin:0 0 22px; }
  .pwtool .privacy strong { color:#065f46; }
  .pwtool .tool { background:var(--bg-soft); border:1px solid var(--border); border-radius:var(--radius); padding:22px; }
  .pwtool label.fld { display:block; font-weight:700; color:var(--brand); margin:0 0 8px; }
  .pwtool .inrow { display:flex; gap:8px; flex-wrap:wrap; }
  .pwtool #pw { flex:1; font-size:1.15rem; padding:13px 14px; border:1.5px solid var(--border-strong); border-radius:10px; font-family:var(--font); min-width:160px; }
  .pwtool #pw:focus { outline:none; border-color:var(--accent-dark); }
  .pwtool .ghost { border:1.5px solid var(--border-strong); background:#fff; border-radius:10px; padding:0 14px; font-weight:700; color:var(--accent-dark); cursor:pointer; font-size:.92rem; white-space:nowrap; }
  .pwtool .ghost:hover { border-color:var(--accent-dark); }
  .pwtool .btn.check { border:none; cursor:pointer; padding:12px 22px; font-size:1rem; }
  .pwtool .result { margin:18px 0 0; border-radius:12px; padding:16px 18px; display:none; }
  .pwtool .result.show { display:block; }
  .pwtool .result.loading { background:var(--bg-soft); border:1px solid var(--border); color:var(--muted); }
  .pwtool .result.bad { background:#fef2f2; border:1px solid #fecaca; border-left:4px solid #dc2626; }
  .pwtool .result.good { background:#ecfdf5; border:1px solid #a7f3d0; border-left:4px solid var(--ok); }
  .pwtool .result.err { background:#fffbeb; border:1px solid #fde68a; border-left:4px solid var(--warn); }
  .pwtool .result h3 { margin:0 0 6px; font-size:1.15rem; }
  .pwtool .result.bad h3 { color:#b91c1c; }
  .pwtool .result.good h3 { color:#065f46; }
  .pwtool .result p { margin:.3em 0 0; font-size:.97rem; color:var(--fg); }
  .pwtool .bignum { font-size:1.55rem; font-weight:800; color:#b91c1c; display:block; margin:2px 0; }
  .pwtool .chips { margin:18px 0 0; font-size:.9rem; color:var(--muted); }
  .pwtool .chip { display:inline-block; margin:5px 6px 0 0; padding:5px 11px; border:1px solid var(--border-strong); border-radius:999px; background:#fff; cursor:pointer; font-size:.85rem; color:var(--accent-dark); font-weight:600; }
  .pwtool .chip:hover { background:var(--bg-soft); }
  .pwtool .cta { margin:26px 0 0; background:linear-gradient(180deg,#fff7ed,#fffdf9); border:1px solid #fed7aa; border-radius:var(--radius); padding:20px 22px; }
  .pwtool .cta h2 { margin:0 0 6px; font-size:1.2rem; color:var(--brand); }
  .pwtool .cta p { margin:0 0 14px; color:#3f4756; font-size:1rem; }
  .pwtool .btn2 { display:inline-block; border:1.5px solid var(--brand); color:var(--brand); background:#fff; text-decoration:none; font-weight:700; padding:9px 16px; border-radius:10px; }
  .pwtool .btn2:hover { background:var(--brand); color:#fff; }
  .pwtool details { margin:24px 0 0; font-size:.95rem; color:var(--muted); }
  .pwtool details summary { cursor:pointer; font-weight:700; color:var(--brand); }
</style>

<script is:inline>
(function(){
  var pwEl=document.getElementById("pw"),resEl=document.getElementById("result"),
      checkBtn=document.getElementById("check"),toggle=document.getElementById("toggle");
  if(!pwEl) return;

  function setResult(cls,html){resEl.className="result show "+cls;resEl.innerHTML=html;}

  async function sha1Hex(str){
    var data=new TextEncoder().encode(str);
    var buf=await crypto.subtle.digest("SHA-1",data);
    var arr=Array.prototype.slice.call(new Uint8Array(buf));
    return arr.map(function(b){return ("0"+b.toString(16)).slice(-2);}).join("").toUpperCase();
  }

  async function check(){
    var pw=pwEl.value;
    if(!pw){setResult("loading","Type a password above, then press Check.");return;}
    setResult("loading","Checking against the breach database…");
    try{
      var hash=await sha1Hex(pw);
      var prefix=hash.slice(0,5),suffix=hash.slice(5);
      var res=await fetch("https://api.pwnedpasswords.com/range/"+prefix,{headers:{"Add-Padding":"true"}});
      if(!res.ok) throw new Error("http "+res.status);
      var text=await res.text();
      var count=0,lines=text.split("\n");
      for(var i=0;i<lines.length;i++){
        var parts=lines[i].trim().split(":");
        if(parts[0]===suffix){count=parseInt(parts[1],10)||0;break;}
      }
      if(count>0){
        setResult("bad","<h3>⚠ Found in known breaches</h3><span class=\"bignum\">"+count.toLocaleString()+" times</span><p>This exact password has appeared in data breaches and is on lists criminals use. If you use it anywhere, change it now — and don't reuse it. A password manager makes that painless.</p>");
      } else {
        setResult("good","<h3>✓ Not found in known breaches</h3><p>This exact password wasn't in Have I Been Pwned's database of 14+ billion leaked passwords. That's good — but “not leaked” isn't the same as “strong.” <a href=\"/tools/password-strength-checker/\">Check how strong it is &rarr;</a></p>");
      }
    }catch(e){
      setResult("err","<h3>Couldn't reach the breach database</h3><p>This can happen on a flaky connection (or inside a sandboxed preview). On the live site it returns in under a second — please try again.</p>");
    }
  }

  checkBtn.addEventListener("click",check);
  pwEl.addEventListener("keydown",function(e){if(e.key==="Enter")check();});
  toggle.addEventListener("click",function(){var t=pwEl.type==="password";pwEl.type=t?"text":"password";this.textContent=t?"Hide":"Show";});
  document.querySelectorAll(".chip").forEach(function(c){c.addEventListener("click",function(){pwEl.type="text";toggle.textContent="Hide";pwEl.value=c.getAttribute("data-pw");check();});});
})();
</script>
