---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CLUSTERS } from '../consts';
import { getCollection } from 'astro:content';

const all = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<BaseLayout
  title="All guides"
  description="Every Stay Safe Guide article in one place: spotting scams, privacy, passwords, VPNs and securing your devices."
>
  <section class="hero">
    <h1>All guides</h1>
    <p class="lead">Everything we've published, grouped by topic. New guides are added regularly.</p>
  </section>

  {CLUSTERS.map((c) => {
    const posts = all.filter((p) => p.data.cluster === c.name);
    return posts.length > 0 ? (
      <section class="section" style={`--c:${c.accent}`}>
        <h2 style="color: var(--c);">{c.icon} {c.name}</h2>
        <ul class="post-list">
          {posts.map((p) => (
            <li>
              <a class="post-title" href={`/articles/${p.slug}/`}>{p.data.title}</a>
              <p class="post-meta">{fmt(p.data.pubDate)}</p>
            </li>
          ))}
        </ul>
        <a class="btn-secondary" href={`/topics/${c.slug}/`}>See the {c.name} section</a>
      </section>
    ) : null;
  })}
</BaseLayout>
