---
import { SITE, NAV } from '../consts';
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href="/">
      <img src="/favicon.svg" alt="" width="28" height="28" />
      <span>{SITE.name}</span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      {NAV.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>
